---
import type { Language } from "@i18n/constants";
import type { BlogEntry } from "../data/blogPosts";
import { useTranslations } from "../i18n/utils";

export interface Props {
	entry: BlogEntry;
	lang: Language;
}

const { entry, lang } = Astro.props;
const t = useTranslations(lang);

const dateLocales = {
	en: "en-US",
	"zh-cn": "zh-CN",
	fr: "fr-FR",
	it: "it-IT",
	es: "es-ES",
	ja: "ja-JP",
	de: "de-DE",
	ru: "ru-RU",
	ko: "ko-KR",
	pt: "pt-PT",
} satisfies Record<Language, Intl.LocalesArgument>;

const formattedDate = new Date(entry.publishedAt).toLocaleDateString(
	dateLocales[lang] ?? "en-US",
	{
		year: "numeric",
		month: "long",
		day: "numeric",
	},
);

const href =
	entry.type === "internal"
		? lang === "en"
			? `/blog/${entry.slug}`
			: `/${lang}/blog/${entry.slug}`
		: entry.url;

const isExternal = entry.type === "external";
const linkText =
	entry.type === "external"
		? t("blog.readMore", entry.platform)
		: t("blog.readArticle");
---

<article class="border border-gray-200 rounded-lg p-4 sm:p-6">
	<h3 class="text-lg sm:text-xl font-semibold text-gray-900 mb-2">
		<a
			href={href}
			{...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
		>
			{entry.title}
		</a>
	</h3>
	<p class="text-gray-600 mb-4">
		{entry.description}
	</p>
	<div class="flex items-center justify-between">
		<time class="text-sm text-gray-500">
			{formattedDate}
		</time>
		<a
			href={href}
			{...(isExternal ? { target: "_blank", rel: "noopener noreferrer" } : {})}
			class="inline-flex items-center text-link font-medium hover:underline"
		>
			{linkText}
			{isExternal ? (
				<svg
					class="w-4 h-4 ml-1"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"
					></path>
				</svg>
			) : (
				<svg
					class="w-4 h-4 ml-1"
					fill="none"
					stroke="currentColor"
					viewBox="0 0 24 24"
				>
					<path
						stroke-linecap="round"
						stroke-linejoin="round"
						stroke-width="2"
						d="M9 5l7 7-7 7"
					></path>
				</svg>
			)}
		</a>
	</div>
</article>
